# Contributor-only deployment/testing variables for ha-nova App.
# Copy to .env.local and fill values (do NOT commit secrets).
#
#   cp .env.example .env.local

# SSH access to Home Assistant host (required for deploy scripts)
HA_HOST=192.168.1.10
HA_SSH_KEY=/Users/<you>/.ssh/id_ed25519
SSH_USER=root
SSH_PORT=22

# App slugs
APP_SLUG=ha_nova_bridge
SUPERVISOR_SLUG=local_ha_nova_bridge

# Live E2E validation (required for smoke:app:e2e)
SUPERVISOR_TOKEN=replace_with_supervisor_token
SUPERVISOR_URL=http://supervisor
BRIDGE_BASE_URL=http://homeassistant.local:8791
BRIDGE_AUTH_TOKEN=replace_with_bridge_auth_token

# Optional for full WS scope in --apply flow
HA_LLAT=
WS_TYPE=ping
