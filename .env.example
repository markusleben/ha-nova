# Contributor-only deployment/testing variables for ha-nova App.
# Minimal setup only. Copy to .env.local and fill values (do NOT commit secrets).
#
#   cp .env.example .env.local

# Required for deploy scripts
HA_HOST=192.168.1.10
HA_SSH_KEY=/Users/<you>/.ssh/id_ed25519

# Live E2E validation
RELAY_BASE_URL=http://homeassistant.local:8791
RELAY_AUTH_TOKEN=replace_with_relay_auth_token
HA_LLAT=replace_with_home_assistant_llat
# Optional override for smoke:app:mvp automation id
# MVP_AUTOMATION_ID=nova_mvp_crud_smoke

# Optional advanced overrides (add only if needed):
# SSH_USER=root
# SSH_PORT=22
# APP_SLUG=ha_nova_relay
# SUPERVISOR_SLUG=local_ha_nova_relay
# SUPERVISOR_TOKEN=
# SUPERVISOR_URL=http://supervisor
