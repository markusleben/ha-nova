#!/usr/bin/with-contenv bashio
set -euo pipefail

export ADDON_OPTIONS_PATH="/data/options.json"
export HA_URL="http://supervisor/core"
export BRIDGE_VERSION="$(bashio::addon.version)"

export BRIDGE_AUTH_TOKEN="$(bashio::config 'bridge_auth_token')"
export HA_LLAT="$(bashio::config 'ha_llat')"
export WS_ALLOWLIST_APPEND="$(bashio::config 'ws_allowlist_append')"

exec node /app/dist/runtime/main.js
