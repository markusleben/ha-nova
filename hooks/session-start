#!/usr/bin/env bash
# SessionStart hook for ha-nova plugin
# Auto-loads the ha-nova context skill into every Claude Code session.

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]:-$0}")" && pwd)"
PLUGIN_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"

# Read context skill content
context_skill_content=$(cat "${PLUGIN_ROOT}/skills/ha-nova/SKILL.md" 2>&1 || echo "Error reading ha-nova context skill")

# Escape string for JSON embedding
escape_for_json() {
    local s="$1"
    s="${s//\\/\\\\}"
    s="${s//\"/\\\"}"
    s="${s//$'\n'/\\n}"
    s="${s//$'\r'/\\r}"
    s="${s//$'\t'/\\t}"
    printf '%s' "$s"
}

context_escaped=$(escape_for_json "$context_skill_content")
session_context="HA NOVA context skill auto-loaded. Sub-skills (ha-nova:read, ha-nova:write, ha-nova:review, ha-nova:entity-discovery, ha-nova:service-call, ha-nova:onboarding) are discovered independently by description.\n\n${context_escaped}"

cat <<EOF
{
  "additional_context": "${session_context}",
  "hookSpecificOutput": {
    "hookEventName": "SessionStart",
    "additionalContext": "${session_context}"
  }
}
EOF

exit 0
